# Copy to .env (gitignored). Pinned knobs for the local stack.

# Postgres — host port 5433: local Homebrew Postgres owns 127.0.0.1:5432
POSTGRES_USER=agora
POSTGRES_PASSWORD=agora_local
POSTGRES_PORT=5433

# Redis — host port 6380: local Homebrew Redis owns 127.0.0.1:6379
REDIS_PORT=6380

# MinIO
MINIO_ROOT_USER=agora
MINIO_ROOT_PASSWORD=agora_local
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Observability (grafana/otel-lgtm)
GRAFANA_PORT=3000
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Redpanda console
CONSOLE_PORT=8085

# Service port map (host): gateway 8080 | link 8081 | identity 8082 | catalog 8083
# search 8084 | inventory 8087 | order 8088 | payment 8089 | chat 8090 | notif 8091
# feed 8092 | location 8093 | analytics 8094 | web-bff 8095 | rate-limiter gRPC 9095

# link-service
LINK_PORT=8081
LINK_DB_URL=postgres://agora:agora_local@localhost:5433/linkdb?sslmode=disable
LINK_REDIS_ADDR=localhost:6380
LINK_MACHINE_ID=1

# edge-gateway
EDGE_PORT=8080

# identity-service
IDENTITY_PORT=8082
# HS256 dev secret (>=32 bytes); identity signs, gateway validates
JWT_SECRET=agora-local-dev-secret-change-me-0123456789abcdef

# rate-limiter
RATELIMIT_GRPC_PORT=9095
RL_REDIS_ADDR=localhost:6380
RL_ALGORITHM=token_bucket
RL_RATE=50
RL_BURST=100

# Image registry (k3d phase)
REGISTRY=localhost:5001
